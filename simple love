    products = loadProductsCSV();

    if (products.empty()) {
        products.push_back({101, "Keyboard", 500, 10});
        products.push_back({102, "Mouse", 200, 5});
    }

    int choice;
    int customerId = 1;

    do {
        menu();
        cin >> choice;

        if (choice == 1) showProducts();

        if (choice == 2) {
            int pid, qty;
            cin >> pid >> qty;
            cout << addToCart(customerId, pid, qty) << endl;
        }

        if (choice == 3) {
            int pid;
            cin >> pid;
            cout << removeFromCart(customerId, pid) << endl;
        }

        if (choice == 4) showCart(customerId);

        if (choice == 5)
            cout << checkout(customerId, "2026-03-09") << endl;

        if (choice == 6) saveProductsCSV();

    } while (choice != 6);

    return 0;
}
