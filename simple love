#include <iostream>
#include <vector>
#include <fstream>
#include <sstream>
#include <cstdlib>
using namespace std;

// ===== PRODUCT =====
class Product {
public:
    int id;
    string name;
    int price;
    int stock;
};

// ===== CART =====
class CartLine {
public:
    int customerId;
    int productId;
    int qty;
};

// ===== ORDER =====
class OrderItem {
public:
    int productId;
    int qty;
};

class Order {
public:
    string orderId;
    int customerId;
    string date;
    vector<OrderItem> items;
};

// ===== GLOBAL =====
vector<Product> products;
vector<CartLine> cart;
vector<Order> orders;

// ===== FILE =====
vector<Product> loadProductsCSV() {
    vector<Product> list;
    ifstream file("products.csv");
    string line;

    while (getline(file, line)) {
        Product p;
        stringstream ss(line);
        string temp;

        getline(ss, temp, ',');
        p.id = atoi(temp.c_str());

        getline(ss, p.name, ',');

        getline(ss, temp, ',');
        p.price = atoi(temp.c_str());

        getline(ss, temp, ',');
        p.stock = atoi(temp.c_str());

        list.push_back(p);
    }

    return list;
}

void saveProductsCSV() {
    ofstream file("products.csv");

    for (const auto &p : 	products) {
        file << p.id << ","
             << p.name << ","
             << p.price << ","
             << p.stock << endl;
    }

    cout << "Saved to products.csv\n";
}

// ===== PRODUCT =====
void showProducts() {
    cout << "\n--- PRODUCT LIST ---\n";
    for (const auto  &p : products) {
        cout << "ID: " << p.id
             << " | Name: " << p.name
             << " | Price: " << p.price
             << " | Stock: " << p.stock << endl;
    }
}

bool productExists(int productId) {
    for (auto p : products)
        if (p.id == productId)
            return true;
    return false;
}

// ===== CART =====
bool addToCart(int customerId, int productId, int qty) {

    if (!productExists(productId) || qty <= 0)
        return false;

    for (auto &c : cart) {
        if (c.customerId == customerId && c.productId == productId) {
            c.qty += qty;
            return true;
        }
    }

    CartLine newLine;
    newLine.customerId = customerId;
    newLine.productId = productId;
    newLine.qty = qty;

    cart.push_back(newLine);
    return true;
}

bool removeFromCart(int customerId, int productId) {

    for (int i = 0; i < cart.size(); i++) {
        if (cart[i].customerId == customerId &&
            cart[i].productId == productId) {

            cart.erase(cart.begin() + i);
            return true;
        }
    }

    return false;
}

void showCart(int customerId) {
    cout << "\n--- CART ---\n";
    for (auto c : cart)
        if (c.customerId == customerId)
            cout << "Product " << c.productId
                 << " | Qty " << c.qty << endl;
}

// ===== ORDER =====
string checkout(int customerId, string date) {

    vector<CartLine> customerCart;

    for (auto c : cart)
        if (c.customerId == customerId)
            customerCart.push_back(c);

    if (customerCart.empty())
        return "false";

    for (auto item : customerCart) {
        for (auto &p : products) {
            if (p.id == item.productId && p.stock < item.qty)
                return "false";
        }
    } // <--- THÊM D?U NÀY (Đóng v?ng l?p ki?m tra kho)

    Order newOrder;
    newOrder.orderId = "ORD" + to_string(orders.size() + 1);
    newOrder.customerId = customerId;
    newOrder.date = date;

    for (auto item : customerCart) {
        OrderItem oi;
        oi.productId = item.productId;
        oi.qty = item.qty;
        newOrder.items.push_back(oi);

        for (auto &p : products) {
            if (p.id == item.productId) {
                p.stock -= item.qty;
            }
        }
    }

    orders.push_back(newOrder);

    for (int i = cart.size() - 1; i >= 0; i--)
        if (cart[i].customerId == customerId)
            cart.erase(cart.begin() + i);

    return newOrder.orderId;
} // <--- THÊM D?U NÀY (Đóng hàm checkout)

